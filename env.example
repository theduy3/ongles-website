# Ongles Maily — environment variables
# Copy to .env.local and fill in. All variable NAMES are unchanged from the
# template; only example values and comments have been updated for this project.

# ── Multi-tenant (build-time) ─────────────────────────────────────────────────
# Selects which branded salon this build serves. One value per domain; defaults to
# maily-beauport. Valid: maily-beauport | ongles-charlesbourg | ongles-rivieres.
# Set it as a Docker --build-arg TENANT=... (see Dockerfile / .github/workflows/deploy.yml),
# not at runtime — it is baked in at build because each domain is its own static build.
TENANT=maily-beauport

# ── Contact form (Resend — https://resend.com) ────────────────────────────────
# Without these, the contact form runs in "not configured" mode
# (see src/app/api/contact/route.ts for the policy).

# API key from the Resend dashboard.
RESEND_API_KEY=

# Verified sender address on your Resend domain,
# e.g. "Ongles Maily <hello@onglesmaily.com>".
CONTACT_FROM_EMAIL=

# Where contact submissions are delivered. Defaults to onglesmailyqc@gmail.com
# (site.contact.email) if unset.
CONTACT_TO_EMAIL=

# ── Popup source (optional) ───────────────────────────────────────────────────
# URL of an endpoint returning the pop-up array
# (see tasks/spec-popup-widget-system.md for the contract). Unset = local
# src/data/popups.json fallback is used.
POPUP_SOURCE_URL=

# ── Supabase (popup admin + newsletter) ──────────────────────────────────────
# Without these, the public site still works (falls back to POPUP_SOURCE_URL /
# popups.json) and the newsletter endpoint runs in dev no-op mode, but the
# /admin portal is disabled and subscriber data is not persisted.
#
# Supabase project URL + anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_ and never import
# into a client component; it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=
# Owner password for the /admin portal login.
ADMIN_PASSWORD=
# Secret used to seal the admin session cookie. Must be at least 32 characters.
ADMIN_SESSION_SECRET=

# ── Google Business Profile API ───────────────────────────────────────────────
# Used only by scripts/fetch-google-reviews.mjs (build-time fetch of real 5★
# reviews; NOT needed at deploy/runtime). OAuth2 refresh-token flow,
# scope https://www.googleapis.com/auth/business.manage.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Numeric IDs from the My Business v4 account/location resource names.
# The Ongles Maily Google Business account and Carrefour Beauport location.
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
